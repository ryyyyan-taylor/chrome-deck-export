{
  "manifest_version": 3,
  "name": "Deck Export",
  "version": "1.0.0",
  "description": "Copy MTG decklists from various sites to your clipboard as plain text.",
  "permissions": ["activeTab", "clipboardWrite", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "deck-export@local",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://mtgtop8.com/*", "*://www.mtgtop8.com/*"],
      "js": ["parsers/registry.js", "parsers/mtgtop8.js", "content.js"]
    }
  ]
}
